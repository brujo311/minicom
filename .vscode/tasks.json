{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Just Build",
      "type": "shell",
      "command": "cd build && cmake .. && cmake --build .",
      "group": "build"
    },
    {
      "label": "Build and Program",
      "type": "shell",
      "command": "cmake --build build --target flash",
      "group": "build"
    }
  ]
}

